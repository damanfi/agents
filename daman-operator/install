#!/usr/bin/env bash
# daman-operator installer.
#
# Builds the daman-operator binary and registers a single service unit
# (`hum-daman-operator`) that runs it. Single bee, single instance, no
# per-bee suffix. There is exactly one operator in the swarm, holding the
# deployer key.
#
# Per /tmp/audit/auth_ops.md Path B: the deployer EOA is the on-chain
# `oracle` AND the `arbiterAddr` on DamanCopyBond, and the implementation
# exposes no setters. The operator daemon is the only path the swarm has
# to submit recordTrade or arbiterRule until a V2 implementation lands via
# the Safe + Timelock ceremony.
#
# Key file:
#   The operator reads its private key from
#   $HOME/.config/hum/daman-operator/operator.key
#   (override via DAMAN_OPERATOR_KEY_PATH).
#
#   The file MUST be:
#     - mode 0600
#     - 64-char hex with NO 0x prefix and NO trailing newline
#     - the deployer private key (same value as PRIVATE_KEY in
#       damanfi/copy-bond/.env, currently the address
#       0x5dF7624bc9845bcEB871652fED33A562E23D8AEd)
#
#   The installer does NOT auto-copy from the .env file. Copy the value
#   manually so a stray chmod on the repo or a future commit can never
#   leak the key. The repo's .env can be chmodded, deleted, or pushed by
#   accident; the standalone keyfile under ~/.config is the source of
#   truth for the running daemon.
#
# Usage:
#   damanfi/agents/daman-operator/install
#   damanfi/agents/daman-operator/install uninstall
#
# Env:
#   DAMAN_OPERATOR_BEE_NAME   default daman-operator
#   DAMAN_OPERATOR_KEY_PATH   default $HOME/.config/hum/daman-operator/operator.key
#   DAMAN_OPERATOR_EOA_ADDR   default derived from key via `cast wallet address`
#   HUM_THRUM_SOCK            default $XDG_RUNTIME_DIR/hum/thrum.sock
#   ARC_TESTNET_RPC           default https://rpc.testnet.arc.network
#   ARC_CHAIN_ID              default 5042002
#   HUM_SVC_HELPER            default $HOME/.local/share/hum/src/scripts/svc.sh
set -euo pipefail

HIVE_DIR="$(cd "$(dirname "$0")" && pwd)"
WORKSPACE_ROOT="$(cd "$HIVE_DIR/.." && pwd)"
BIN_NAME="daman-operator"
BIN="$HOME/.local/bin/${BIN_NAME}"

BEE_NAME="${DAMAN_OPERATOR_BEE_NAME:-daman-operator}"
KEY_PATH="${DAMAN_OPERATOR_KEY_PATH:-$HOME/.config/hum/daman-operator/operator.key}"
EOA_ADDR="${DAMAN_OPERATOR_EOA_ADDR:-}"
UNIT_NAME="hum-${BIN_NAME}"

if [ -n "${XDG_RUNTIME_DIR:-}" ]; then
  DEFAULT_SOCK="$XDG_RUNTIME_DIR/hum/thrum.sock"
else
  DEFAULT_SOCK="/tmp/hum-$(id -u)/thrum.sock"
fi
THRUM_SOCK="${HUM_THRUM_SOCK:-$DEFAULT_SOCK}"
ARC_RPC="${ARC_TESTNET_RPC:-https://rpc.testnet.arc.network}"
ARC_CHAIN_ID="${ARC_CHAIN_ID:-5042002}"

log()  { printf '\033[1m[%s]\033[0m %s\n' "$UNIT_NAME" "$*"; }
warn() { printf '\033[1;33m[%s]\033[0m %s\n' "$UNIT_NAME" "$*" >&2; }
fail() { printf '\033[1;31m[%s]\033[0m %s\n' "$UNIT_NAME" "$*" >&2; exit 1; }

SVC="${HUM_SVC_HELPER:-$HOME/.local/share/hum/src/scripts/svc.sh}"
if [ ! -f "$SVC" ] && [ -f "$HOME/hum/scripts/svc.sh" ]; then
  SVC="$HOME/hum/scripts/svc.sh"
fi
[ -f "$SVC" ] || fail "scripts/svc.sh not found at $SVC (set HUM_SVC_HELPER to override)"
# shellcheck source=/dev/null
. "$SVC"

build() {
  command -v cargo >/dev/null 2>&1 || fail "cargo unavailable, can't build $BIN_NAME"
  log "building $BIN_NAME (always rebuild on install; cargo will re-use incremental cache)"
  ( cd "$WORKSPACE_ROOT" && cargo install --quiet --locked --path "$HIVE_DIR" --root "$HOME/.local" --force --bin "$BIN_NAME" )
  [ -x "$BIN" ] || fail "binary missing after build: $BIN"
  log "built: $BIN"
}

check_key() {
  if [ ! -f "$KEY_PATH" ]; then
    fail "operator key file missing at $KEY_PATH
Create it manually:
  mkdir -p \"$(dirname "$KEY_PATH")\"
  chmod 700 \"$(dirname "$KEY_PATH")\"
  # paste the deployer PRIVATE_KEY value (64-char hex, no 0x, no newline)
  printf '%s' '<paste-deployer-private-key-hex>' > \"$KEY_PATH\"
  chmod 600 \"$KEY_PATH\"
The deployer key is the same value as PRIVATE_KEY in damanfi/copy-bond/.env.
Do NOT symlink to the .env file: a stray chmod or commit on the repo would leak it."
  fi
  if ! [ -r "$KEY_PATH" ]; then
    fail "operator key file unreadable: $KEY_PATH"
  fi
  # Mode check: any group or world bits set means refuse to start.
  local mode
  if stat -f '%Lp' "$KEY_PATH" >/dev/null 2>&1; then
    mode=$(stat -f '%Lp' "$KEY_PATH")    # BSD / macOS
  else
    mode=$(stat -c '%a' "$KEY_PATH")     # GNU / Linux
  fi
  case "$mode" in
    600|400) ;;
    *) fail "operator key file $KEY_PATH has mode $mode; required 0600 (chmod 600 it)" ;;
  esac
}

derive_addr_if_needed() {
  if [ -z "$EOA_ADDR" ] && [ -r "$KEY_PATH" ]; then
    if command -v cast >/dev/null 2>&1; then
      EOA_ADDR=$(cast wallet address --private-key "0x$(cat "$KEY_PATH")")
      log "derived EOA address from key: $EOA_ADDR"
    fi
  fi
  [ -n "$EOA_ADDR" ] || warn "EOA_ADDR empty (cast unavailable?); binary will derive from the signer at runtime"
}

install_unit() {
  case "$SVC_OS" in
    Linux|Darwin) ;;
    *) warn "unsupported OS $SVC_OS, run '$BIN ...' manually"; return 0 ;;
  esac
  check_key
  derive_addr_if_needed
  local exec_line="$BIN --bee-name $BEE_NAME --eoa-addr ${EOA_ADDR:-0x0000000000000000000000000000000000000000} --key-path $KEY_PATH"
  svc_install "$UNIT_NAME" "$exec_line" \
    --env "HUM_LOG_LEVEL=info" \
    --env "RUST_LOG=info" \
    --env "XDG_RUNTIME_DIR=${XDG_RUNTIME_DIR:-/run/user/$(id -u)}" \
    --env "XDG_STATE_HOME=${XDG_STATE_HOME:-$HOME/.local/state}" \
    --env "HUM_THRUM_SOCK=$THRUM_SOCK" \
    --env "ARC_TESTNET_RPC=$ARC_RPC" \
    --env "ARC_CHAIN_ID=$ARC_CHAIN_ID" \
    --env "PATH=$HOME/.local/bin:/usr/local/bin:/usr/bin:/bin" \
    --env "HOME=$HOME"
  svc_restart "$UNIT_NAME" 2>/dev/null || svc_start "$UNIT_NAME" 2>/dev/null || true
  sleep 1
  if svc_is_active "$UNIT_NAME"; then
    log "running"
  else
    warn "did not start cleanly"
  fi
}

uninstall() {
  svc_uninstall "$UNIT_NAME" 2>/dev/null || true
  log "uninstalled."
}

case "${1:-install}" in
  install|"") build && install_unit ;;
  uninstall) uninstall ;;
  *) fail "unknown command: $1 (try: install, uninstall)" ;;
esac
