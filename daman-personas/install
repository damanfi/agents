#!/usr/bin/env bash
# daman-persona installer — one invocation per bee. Builds the binary once
# (idempotent), then registers a per-bee service unit via the hum svc helper.
# Each bee runs as `hum-daman-persona-<bee_name>`; `hum bee <bee> enter|exit|reenter`
# manages its lifecycle going forward.
#
# Per BRIEF_PERSONA_AS_FORAGER: each persona is its own forager process holding one
# EOA private key, one stable ed25519 hid, one namespaced tool surface. Process
# boundary = identity boundary, mirroring humfs's per-instance fs.roots scoping.
#
# Usage:
#   DAMAN_PERSONA_BEE_NAME=daman-leader-alpha \
#   DAMAN_PERSONA_ROLE=leader \
#   DAMAN_PERSONA_VARIANT=alpha \
#   DAMAN_PERSONA_KEY_PATH=~/.config/hum/daman-personas/daman-leader-alpha.key \
#   DAMAN_PERSONA_EOA_ADDR=0x... \
#   damanfi/agents/daman-personas/install
#
#   damanfi/agents/daman-personas/install uninstall   # remove the unit for this bee
#
# Env:
#   HUM_THRUM_SOCK       default $XDG_RUNTIME_DIR/hum/thrum.sock
#   ARC_TESTNET_RPC      default https://rpc.testnet.arc.network
#   ARC_CHAIN_ID         default 5042002
#   HUM_SVC_HELPER       default $HOME/.local/share/hum/src/scripts/svc.sh
set -euo pipefail

HIVE_DIR="$(cd "$(dirname "$0")" && pwd)"
WORKSPACE_ROOT="$(cd "$HIVE_DIR/.." && pwd)"
BIN_NAME="daman-persona"
BIN="$HOME/.local/bin/${BIN_NAME}"

BEE_NAME="${DAMAN_PERSONA_BEE_NAME:?DAMAN_PERSONA_BEE_NAME is required}"
ROLE="${DAMAN_PERSONA_ROLE:?DAMAN_PERSONA_ROLE is required}"
VARIANT="${DAMAN_PERSONA_VARIANT:-alpha}"
KEY_PATH="${DAMAN_PERSONA_KEY_PATH:-$HOME/.config/hum/daman-personas/${BEE_NAME}.key}"
EOA_ADDR="${DAMAN_PERSONA_EOA_ADDR:-}"
UNIT_NAME="hum-${BIN_NAME}-${BEE_NAME}"

if [ -n "${XDG_RUNTIME_DIR:-}" ]; then
  DEFAULT_SOCK="$XDG_RUNTIME_DIR/hum/thrum.sock"
else
  DEFAULT_SOCK="/tmp/hum-$(id -u)/thrum.sock"
fi
THRUM_SOCK="${HUM_THRUM_SOCK:-$DEFAULT_SOCK}"
ARC_RPC="${ARC_TESTNET_RPC:-https://rpc.testnet.arc.network}"
ARC_CHAIN_ID="${ARC_CHAIN_ID:-5042002}"

log()  { printf '\033[1m[%s]\033[0m %s\n' "$UNIT_NAME" "$*"; }
warn() { printf '\033[1;33m[%s]\033[0m %s\n' "$UNIT_NAME" "$*" >&2; }
fail() { printf '\033[1;31m[%s]\033[0m %s\n' "$UNIT_NAME" "$*" >&2; exit 1; }

SVC="${HUM_SVC_HELPER:-$HOME/.local/share/hum/src/scripts/svc.sh}"
if [ ! -f "$SVC" ] && [ -f "$HOME/hum/scripts/svc.sh" ]; then
  SVC="$HOME/hum/scripts/svc.sh"
fi
[ -f "$SVC" ] || fail "scripts/svc.sh not found at $SVC (set HUM_SVC_HELPER to override)"
# shellcheck source=/dev/null
. "$SVC"

build() {
  if [ -x "$BIN" ]; then
    log "binary present: $BIN (skipping cargo)"
    return 0
  fi
  command -v cargo >/dev/null 2>&1 || fail "no $BIN and cargo unavailable"
  log "building $BIN_NAME"
  ( cd "$WORKSPACE_ROOT" && cargo install --quiet --locked --path "$HIVE_DIR" --root "$HOME/.local" --force --bin "$BIN_NAME" )
  [ -x "$BIN" ] || fail "binary missing after build: $BIN"
  log "built: $BIN"
}

derive_addr_if_needed() {
  if [ -z "$EOA_ADDR" ] && [ -r "$KEY_PATH" ]; then
    if command -v cast >/dev/null 2>&1; then
      EOA_ADDR=$(cast wallet address --private-key "0x$(cat "$KEY_PATH")")
      log "derived EOA address from key: $EOA_ADDR"
    fi
  fi
  [ -n "$EOA_ADDR" ] || warn "EOA_ADDR empty — persona will surface 0x0 in its system prompt"
}

install_unit() {
  case "$SVC_OS" in
    Linux|Darwin) ;;
    *) warn "unsupported OS $SVC_OS — run '$BIN ...' manually"; return 0 ;;
  esac
  [ -r "$KEY_PATH" ] || fail "key file unreadable: $KEY_PATH"
  derive_addr_if_needed
  local exec_line="$BIN --role $ROLE --variant $VARIANT --bee-name $BEE_NAME --eoa-addr ${EOA_ADDR:-0x0000000000000000000000000000000000000000} --key-path $KEY_PATH"
  svc_install "$UNIT_NAME" "$exec_line" \
    --env "HUM_LOG_LEVEL=info" \
    --env "RUST_LOG=info" \
    --env "XDG_RUNTIME_DIR=${XDG_RUNTIME_DIR:-/run/user/$(id -u)}" \
    --env "XDG_STATE_HOME=${XDG_STATE_HOME:-$HOME/.local/state}" \
    --env "HUM_THRUM_SOCK=$THRUM_SOCK" \
    --env "ARC_TESTNET_RPC=$ARC_RPC" \
    --env "ARC_CHAIN_ID=$ARC_CHAIN_ID" \
    --env "PATH=$HOME/.local/bin:/usr/local/bin:/usr/bin:/bin" \
    --env "HOME=$HOME"
  svc_restart "$UNIT_NAME" 2>/dev/null || svc_start "$UNIT_NAME" 2>/dev/null || true
  sleep 1
  if svc_is_active "$UNIT_NAME"; then
    log "running ✓"
  else
    warn "did not start cleanly"
  fi
}

uninstall() {
  svc_uninstall "$UNIT_NAME" 2>/dev/null || true
  log "uninstalled."
}

case "${1:-install}" in
  install|"") build && install_unit ;;
  uninstall) uninstall ;;
  *) fail "unknown command: $1 (try: install, uninstall)" ;;
esac
